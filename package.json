{
  "name": "opendoc",
  "version": "0.0.1",
  "description": "Git-native docs and wiki. Replaces GitBook and Obsidian. MCP-native.",
  "homepage": "https://opendoc.sh",
  "repository": "https://github.com/maketh-labs/opendoc",
  "license": "MIT",
  "type": "module",
  "bin": {
    "opendoc": "./bin/opendoc.js"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:binary": "bun build --compile src/cli.ts --outfile opendoc",
    "prepublishOnly": "bun run scripts/build.ts",
    "test": "bun test tests/unit tests/integration",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "test:all": "bun test tests/"
  },
  "files": [
    "bin/",
    "src/",
    "themes/",
    "client/",
    "tailwind.config.js",
    "README.md"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.11",
    "playwright": "^1.58.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@blocknote/code-block": "^0.47.3",
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shikijs/rehype": "^4.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emoji-mart": "^5.6.0",
    "lucide-react": "^1.7.0",
