{
  "name": "opendoc",
  "version": "0.1.0",
  "description": "Git-native docs and wiki. Replaces GitBook and Obsidian. MCP-native.",
  "homepage": "https://opendoc.sh",
  "repository": "https://github.com/maketh-labs/opendoc",
  "license": "MIT",
  "type": "module",
  "bin": {
    "opendoc": "./bin/opendoc.js"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:binary": "bun build --compile src/cli.ts --outfile opendoc",
    "prepublishOnly": "bun run scripts/build.ts"
  },
  "optionalDependencies": {
    "opendoc-darwin-arm64": "0.1.0",
    "opendoc-darwin-x64": "0.1.0",
    "opendoc-linux-x64": "0.1.0",
    "opendoc-linux-arm64": "0.1.0",
    "opendoc-win32-x64": "0.1.0"
  },
  "files": [
    "bin/",
    "src/",
    "themes/",
    "client/",
    "README.md"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chokidar": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "simple-git": "^3.33.0",
    "unified": "^11.0.5",
    "vite": "^8.0.3"
  }
}
